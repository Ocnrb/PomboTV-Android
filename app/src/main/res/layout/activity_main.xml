<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- ======================= HOME ======================= -->
    <ScrollView
        android:id="@+id/pageHome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PomboTV"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="P2P live streaming · Streamr"
                        android:textColor="@color/muted"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/gearBtn"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_roundbtn"
                    android:contentDescription="Settings"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/muted" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/statusDot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="@color/warn"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="monospace"
                    android:text="connecting…"
                    android:textColor="@color/muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/liveBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_live"
                android:paddingStart="9dp"
                android:paddingTop="4dp"
                android:paddingEnd="9dp"
                android:paddingBottom="4dp"
                android:text="●  LIVE now — someone is broadcasting"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/goLive"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_btn_primary"
                android:text="Go Live"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/goWatch"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_btn_secondary"
                android:text="Watch"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

    <!-- ======================= NETWORK (gear) ======================= -->
    <ScrollView
        android:id="@+id/pageNetwork"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/netBack"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_roundbtn"
                    android:contentDescription="Back"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_back" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:text="Network"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.1"
                    android:text="OPERATOR PROXIES"
                    android:textColor="@color/muted"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Broadcast (publish)"
                            android:textColor="@color/muted"
                            android:textSize="11sp" />

                        <Spinner
                            android:id="@+id/proxyPubSel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Watch (subscribe)"
                            android:textColor="@color/muted"
                            android:textSize="11sp" />

                        <Spinner
                            android:id="@+id/proxySubSel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="0 = P2P mesh · 1–3 = via operator nodes (requires an active sponsorship)"
                    android:textColor="@color/muted"
                    android:textSize="10sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ======================= BROADCAST SETUP ======================= -->
    <ScrollView
        android:id="@+id/pageSettings"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="New broadcast"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.1"
                    android:text="VIDEO"
                    android:textColor="@color/muted"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Resolution"
                            android:textColor="@color/muted"
                            android:textSize="11sp" />

                        <Spinner
                            android:id="@+id/resSel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Camera"
                            android:textColor="@color/muted"
                            android:textSize="11sp" />

                        <Spinner
                            android:id="@+id/camSel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/brLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Bitrate 2.0 Mbps"
                    android:textColor="@color/fg"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/bitrate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="75"
                    android:progress="15" />

                <TextView
                    android:id="@+id/kfLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Keyframe 1.0 s"
                    android:textColor="@color/fg"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/kf"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="14"
                    android:progress="2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Audio bitrate"
                    android:textColor="@color/muted"
                    android:textSize="11sp" />

                <Spinner
                    android:id="@+id/audioSel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/settingsBack"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_secondary"
                    android:text="Cancel"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/startBtn"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_primary"
                    android:text="Go Live"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/settingsStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="16dp"
                android:textColor="@color/error"
                android:textSize="11sp" />
        </LinearLayout>
    </ScrollView>

    <!-- ======================= BROADCAST ======================= -->
    <FrameLayout
        android:id="@+id/pageBroadcast"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone">

        <com.livepoc.android.AspectFrameLayout
            android:id="@+id/previewBox"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center">

            <SurfaceView
                android:id="@+id/previewSurface"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </com.livepoc.android.AspectFrameLayout>

        <LinearLayout
            android:id="@+id/bTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_live"
                android:paddingStart="9dp"
                android:paddingTop="3dp"
                android:paddingEnd="9dp"
                android:paddingBottom="3dp"
                android:text="LIVE"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/bTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip"
                android:fontFamily="monospace"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/bMeter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip"
                android:fontFamily="monospace"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp"
                android:textColor="@color/fg"
                android:textSize="11sp" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/bStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/muted"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/bStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="88dp"
            android:background="@drawable/bg_console"
            android:fontFamily="monospace"
            android:padding="10dp"
            android:textColor="@color/stats"
            android:textSize="10sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/bControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/zoomChip"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_roundbtn"
                android:gravity="center"
                android:text="1.0×"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/micBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_roundbtn"
                android:contentDescription="Mute microphone"
                android:scaleType="centerInside"
                android:src="@drawable/ic_mic" />

            <ImageButton
                android:id="@+id/torchBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_roundbtn"
                android:contentDescription="Torch"
                android:scaleType="centerInside"
                android:src="@drawable/ic_flash" />

            <ImageButton
                android:id="@+id/bConsoleBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_roundbtn"
                android:contentDescription="Console"
                android:scaleType="centerInside"
                android:src="@drawable/ic_code" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/stopBtn"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@drawable/bg_stop"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:text="End"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <!-- ======================= WATCH ======================= -->
    <FrameLayout
        android:id="@+id/pageWatch"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone">

        <com.livepoc.android.AspectFrameLayout
            android:id="@+id/watchBox"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center">

            <SurfaceView
                android:id="@+id/watchSurface"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </com.livepoc.android.AspectFrameLayout>

        <ProgressBar
            android:id="@+id/wSpinner"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:indeterminate="true" />

        <LinearLayout
            android:id="@+id/wTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_live"
                android:paddingStart="9dp"
                android:paddingTop="3dp"
                android:paddingEnd="9dp"
                android:paddingBottom="3dp"
                android:text="LIVE"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/wTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip"
                android:fontFamily="monospace"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/wMeter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip"
                android:fontFamily="monospace"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp"
                android:textColor="@color/fg"
                android:textSize="11sp" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/wStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="@color/muted"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/wStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="88dp"
            android:background="@drawable/bg_console"
            android:fontFamily="monospace"
            android:padding="10dp"
            android:textColor="@color/stats"
            android:textSize="10sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/wControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <ImageButton
                android:id="@+id/ppBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_roundbtn"
                android:contentDescription="Pause"
                android:scaleType="centerInside"
                android:src="@drawable/ic_pause" />

            <ImageButton
                android:id="@+id/muteBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_roundbtn"
                android:contentDescription="Mute"
                android:scaleType="centerInside"
                android:src="@drawable/ic_volume_up" />

            <SeekBar
                android:id="@+id/volumeBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="100" />

            <ImageButton
                android:id="@+id/wConsoleBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_roundbtn"
                android:contentDescription="Console"
                android:scaleType="centerInside"
                android:src="@drawable/ic_code" />

            <ImageButton
                android:id="@+id/fsBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_roundbtn"
                android:contentDescription="Fullscreen"
                android:scaleType="centerInside"
                android:src="@drawable/ic_fullscreen" />

            <Button
                android:id="@+id/leaveBtn"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_leave"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:text="Leave"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
