<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="8dp"
    android:paddingEnd="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Source"
        android:textColor="@color/muted"
        android:textSize="11sp" />

    <Spinner
        android:id="@+id/meetSourceSel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Video quality"
        android:textColor="@color/muted"
        android:textSize="11sp" />

    <Spinner
        android:id="@+id/meetQualitySel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Audio bitrate"
        android:textColor="@color/muted"
        android:textSize="11sp" />

    <Spinner
        android:id="@+id/meetAudioSel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <CheckBox
        android:id="@+id/meetAdaptCb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:checked="true"
        android:text="Adaptive bitrate (scales down as participants join)"
        android:textColor="@color/fg"
        android:textSize="12sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Each participant takes a slot (#0-#8). Others appear automatically."
        android:textColor="@color/muted"
        android:textSize="10sp" />
</LinearLayout>
